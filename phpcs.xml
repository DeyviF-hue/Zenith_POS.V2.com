<?xml version="1.0"?>
<ruleset name="LaravelApp" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="vendor/squizlabs/php_codesniffer/php_codesniffer.rulestack.xsd">
    <description>PHP CodeSniffer configuration for Laravel project</description>
    <file>app</file>
    <file>tests</file>
    <exclude-pattern>vendor/*</exclude-pattern>

    <rule ref="PSR12"/>
    <rule ref="Generic.WhiteSpace.DisallowSpaceIndent"/>
</ruleset>
